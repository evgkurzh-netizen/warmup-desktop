{
  "name": "warmup-desktop-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": "./dist/capture.cjs",
  "scripts": {
    "build:js": "esbuild src/capture.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/capture.cjs --external:patchright --external:patchright-core --external:proxy-chain --external:fsevents --external:bufferutil --external:utf-8-validate --external:chromium-bidi --external:electron",
    "build:stage": "node ./build.mjs",
    "build": "pnpm run build:js && pnpm run build:stage"
  },
  "dependencies": {
    "patchright": "1.60.0",
    "patchright-core": "1.60.0",
    "proxy-chain": "2.5.6"
  },
  "devDependencies": {
    "esbuild": "0.27.3"
  }
}
