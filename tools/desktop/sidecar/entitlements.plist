<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow V8 to allocate writable+executable memory (MAP_JIT) on Apple
       Silicon. Without this entitlement the kernel kills the process with
       SIGTRAP the moment V8 tries to set up its CodeRange. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- pkg's Node binary loads its V8 snapshot via dlopen-style mechanisms
       that hardened runtime would otherwise block. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
